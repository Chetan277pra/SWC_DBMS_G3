
CREATE TABLE Department (
    Id INT PRIMARY KEY,
    Name VARCHAR(50)
);
-- DROP TABLE Department
-- DROP TABLE Employee
CREATE TABLE Employee (
    Id INT PRIMARY KEY,
    Name VARCHAR(50),
    Salary INT,
    DepartmentId INT REFERENCES Department(Id)
);

