SELECT Department , Name , Salary
FROM (
SELECT B.Name as Department , A.Name  , A.Salary,
DENSE_RANK() OVER(PARTITION BY A.DepartmentId  ORDER BY A.Salary desc) AS DR
FROM Employee A
JOIN Department B  
ON DepartmentId = B.Id
) WHERE DR <= 3


