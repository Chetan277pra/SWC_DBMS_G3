SELECT
    p.sub_id AS post_id,
    COUNT(c.sub_id) AS number_of_comments FROM
(
    SELECT DISTINCT sub_id, parent_id
    FROM Submissions
) p LEFT JOIN
(
    SELECT DISTINCT sub_id, parent_id
    FROM Submissions
) c
ON p.sub_id = c.parent_id
WHERE p.parent_id IS NULL
GROUP BY p.sub_id
ORDER BY p.sub_id;